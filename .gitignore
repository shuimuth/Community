
# =============================================
# uni-app Project .gitignore
# =============================================

# ----- Build Output / Compiled Files -----
# uni-app build output directory
unpackage/

# ----- Dependencies -----
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----- IDE / Editor Config -----
# HBuilderX
.hbuilderx/

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.#*

# ----- OS Generated Files -----
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----- Environment & Sensitive Config -----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# ----- TypeScript -----
*.tsbuildinfo

# ----- Testing -----
coverage/
.nyc_output/

# ----- Misc -----
*.local
*.bak
*.tmp
*.temp
*.orig

# ----- uni-app Specific -----
# Local uni-app debug config
.hbuilderx/

# uni-app compiler cache
.uni/

# wxcomponents build cache (if any)
wxcomponents/

# ----- uniCloud Specific -----
# uniCloud local debugging config (auto-generated)
uniCloud-alipay/cloudfunctions/.secret
uniCloud-alipay/cloudfunctions/**/node_modules/
uniCloud-tcb/cloudfunctions/.secret
uniCloud-tcb/cloudfunctions/**/node_modules/

# Cloud function local run logs
uniCloud-alipay/cloudfunctions/**/*.log
uniCloud-tcb/cloudfunctions/**/*.log

# ----- AI / CodeBuddy Config -----
.codebuddy/

# ----- Other -----
# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock
