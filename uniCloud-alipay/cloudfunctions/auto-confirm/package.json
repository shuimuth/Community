{
  "name": "auto-confirm",
  "dependencies": {},
  "main": "index.js",
  "extensions": {
    "uni-cloud-jql": {}
  },
  "cloudfunction-config": {
    "concurrency": 1,
    "memorySize": 256,
    "timeout": 60,
    "triggers": [
      {
        "name": "auto-confirm-timer",
        "type": "timer",
        "config": "0 0 */1 * * * *"
      }
    ]
  }
}
