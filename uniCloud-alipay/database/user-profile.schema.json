{
  "bsonType": "object",
  "required": ["user_id"],
  "permission": {
    "read": "doc.user_id == auth.uid || 'admin' in auth.role",
    "create": true,
    "update": "doc.user_id == auth.uid || 'admin' in auth.role",
    "delete": "'admin' in auth.role"
  },
  "properties": {
    "_id": {
      "description": "ID"
    },
    "user_id": {
      "bsonType": "string",
      "title": "User ID",
      "description": "Associated uni-id-users._id",
      "foreignKey": "uni-id-users._id",
      "trim": "both"
    },
    "credit_score": {
      "bsonType": "int",
      "title": "Credit Score",
      "description": "User credit score (initial: 100)",
      "defaultValue": 100,
      "minimum": 0,
      "maximum": 200
    },
    "balance": {
      "bsonType": "number",
      "title": "Balance",
      "description": "Available account balance (CNY)",
      "defaultValue": 0,
      "minimum": 0
    },
    "frozen_balance": {
      "bsonType": "number",
      "title": "Frozen Balance",
      "description": "Frozen balance during pending operations",
      "defaultValue": 0,
      "minimum": 0
    },
    "real_name": {
      "bsonType": "string",
      "title": "Real Name",
      "description": "User's real name (for identity verification)",
      "trim": "both"
    },
    "id_card": {
      "bsonType": "string",
      "title": "ID Card",
      "description": "Identity card number (encrypted storage)"
    },
    "is_verified": {
      "bsonType": "bool",
      "title": "Is Verified",
      "description": "Whether identity verification is completed",
      "defaultValue": false
    },
    "verified_at": {
      "bsonType": "timestamp",
      "title": "Verified At",
      "description": "Timestamp when identity verification was completed"
    },
    "points": {
      "bsonType": "int",
      "title": "Points",
      "description": "Points balance (reserved for future use)",
      "defaultValue": 0
    },
    "member_level": {
      "bsonType": "int",
      "title": "Member Level",
      "description": "Member level (reserved for future use)",
      "defaultValue": 0
    },
    "is_merchant": {
      "bsonType": "bool",
      "title": "Is Merchant",
      "description": "Whether user is a merchant (reserved for e-commerce)",
      "defaultValue": false
    },
    "task_published_count": {
      "bsonType": "int",
      "title": "Published Task Count",
      "description": "Number of tasks published by user",
      "defaultValue": 0
    },
    "task_completed_count": {
      "bsonType": "int",
      "title": "Completed Task Count",
      "description": "Number of tasks completed by user",
      "defaultValue": 0
    },
    "last_login_at": {
      "bsonType": "timestamp",
      "title": "Last Login At",
      "description": "Last login timestamp"
    },
    "created_at": {
      "bsonType": "timestamp",
      "title": "Created At",
      "description": "Profile creation timestamp"
    },
    "updated_at": {
      "bsonType": "timestamp",
      "title": "Updated At",
      "description": "Last update timestamp"
    }
  }
}